      "reason": "常规巡检使用 camera profile 推导出的默认策略。"
    },
    "focused": {
      "confidence_delta": -0.05,
      "duration_multiplier": 1.3,
      "interval_multiplier": 0.8,
      "reason": "重点巡检会延长检测时间并提高抽帧密度。"
    }
  },
  "risk_thresholds": {
    "high_confidence": 0.75,
    "medium_confidence": 0.5,
    "low_confidence": 0.3,
    "transient_fire_confidence": 0.8,
