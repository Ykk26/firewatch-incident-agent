  "scene_reasoning_guidance": {
    "kitchen": {
      "common_false_positive_patterns": ["蒸汽", "油烟", "正常炉灶明火"],
      "policy": "厨房场景中 smoke 容易由蒸汽或油烟造成误报，应提高明火证据权重，并结合连续帧和 fire/smoke 组合判断是否告警。",
      "alert_bias": {
        "fire_weight": 1.3,
        "smoke_weight": 0.8,
        "allow_transient_fire": true,
        "require_temporal_for_smoke_only": true,
        "followup_on_transient": true
      }
    },
    "outdoor": {
      "common_false_positive_patterns": ["阳光反射", "车灯", "远处灯光"],
      "policy": "室外场景容易出现 fire-like 反光，单帧低置信度不应直接升级，应要求更多连续帧或 smoke 伴随。",
      "alert_bias": {
        "fire_weight": 0.9,
        "smoke_weight": 1.0,
        "allow_transient_fire": true,
        "require_temporal_for_smoke_only": true,
        "followup_on_transient": true
      }
    },
    "electrical_room": {
      "common_false_positive_patterns": ["低照度噪声", "设备反光"],
      "policy": "配电间应重视 smoke，即使置信度不高也应密集观察，但仍需人工复核。",
      "alert_bias": {
        "fire_weight": 1.1,
        "smoke_weight": 1.3,
        "allow_transient_fire": true,
        "require_temporal_for_smoke_only": false,
        "followup_on_transient": true
      }
    },
    "warehouse": {
      "common_false_positive_patterns": ["叉车灯", "焊接火花", "货架遮挡"],
      "policy": "仓库场景火势扩散影响较高，连续 fire 或 fire+smoke 应提高优先级。",
      "alert_bias": {
        "fire_weight": 1.2,
        "smoke_weight": 1.1,
        "allow_transient_fire": true,
        "require_temporal_for_smoke_only": true,
        "followup_on_transient": true
      }
    },
    "unknown": {
      "common_false_positive_patterns": [],
      "policy": "未知场景不做强假设，先使用平衡策略，依赖多帧连续性和后续人工反馈修正画像。",
      "alert_bias": {
        "fire_weight": 1.0,
        "smoke_weight": 1.0,
        "allow_transient_fire": true,
        "require_temporal_for_smoke_only": true,
        "followup_on_transient": true
      }
    }
  },
